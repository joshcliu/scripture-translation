{
  "base_model_name": "mistralai/Mistral-7B-Instruct-v0.2",
  "default_target_lang": "es",
  "adapter_paths": {
    "bible": "models/adapters/bible_adapter",
    "ministry": "models/adapters/ministry_adapter"
  },
  "tinker": {
    "base_url_env": "TINKER_API_BASE_URL",
    "token_env": "TINKER_API_TOKEN",
    "dataset_upload_path": "/datasets",
    "job_create_path": "/fine-tunes",
    "job_status_path_template": "/fine-tunes/{job_id}",
    "download_url_field": "adapter_download_url"
  }
}
